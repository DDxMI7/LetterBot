# ── Telegram ──────────────────────────────────────────────────────────────────
# Token vom @BotFather (https://t.me/BotFather → /newbot)
TELEGRAM_TOKEN=dein_token_hier

# Deine eigene Telegram-User-ID (hol dir diese von @userinfobot)
ALLOWED_USER_ID=123456789

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434

# Empfehlung für RTX 4070:
#   llama3.2      – schnell, gut für Deutsch (Standard)
#   mistral       – sehr gut für strukturierte Extraktion
#   llama3.1:8b   – etwas langsamer aber präziser
OLLAMA_MODEL=llama3.2

# ── Google Calendar ───────────────────────────────────────────────────────────
# Pfad zur credentials.json aus der Google Cloud Console
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.pickle

# "primary" = Hauptkalender, oder Kalender-ID (z.B. abc123@group.calendar.google.com)
GOOGLE_CALENDAR_ID=primary

# ── Einstellungen ─────────────────────────────────────────────────────────────
TIMEZONE=Europe/Berlin

# "true" um PaddleOCR statt Tesseract zu nutzen (bessere Qualität, mehr RAM)
USE_PADDLEOCR=false
